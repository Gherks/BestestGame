@page "/tournaments"
@rendermode InteractiveServer
@using BestestGame.Models
@using BestestGame.Services
@inject GameService GameService
@inject NavigationManager Navigation

<PageTitle>Tournaments | Arena Select 🏟️</PageTitle>

<section class="relative overflow-hidden rounded-3xl border-2 border-fuchsia-400/30 bg-white/10 p-6 shadow-2xl shadow-fuchsia-900/50 backdrop-blur-xl md:p-8 animate-fade-in-up">
    <div class="pointer-events-none absolute -left-12 top-16 h-44 w-44 rounded-full bg-orange-500/30 blur-3xl animate-pulse"></div>
    <div class="pointer-events-none absolute -right-8 bottom-10 h-36 w-36 rounded-full bg-fuchsia-500/25 blur-3xl animate-pulse" style="animation-delay: 0.7s;"></div>

    <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-display text-3xl font-black text-white md:text-4xl">
            <span class="animate-wiggle inline-block">🏟️</span>
            TOURNAMENT HQ
        </h1>
        <span class="rounded-full bg-fuchsia-500/30 border-2 border-fuchsia-400/50 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-fuchsia-200 animate-pulse">COMMAND CENTER</span>
    </div>

    <p class="mt-3 text-slate-100/90">
        Create a tournament, give it a legendary name, and start filling it with games.
        <span class="text-xs text-slate-400 block mt-1">
            Every tournament is its own universe of duels. Multiverse of madness? More like multiverse of rankings. 🌀
        </span>
    </p>

    <!-- Create new tournament -->
    <div class="mt-6 rounded-2xl border-2 border-green-400/25 bg-black/30 p-5 backdrop-blur-lg">
        <h2 class="text-sm font-black uppercase tracking-[0.18em] text-green-200 flex items-center gap-2">
            <span class="animate-floaty inline-block">✨</span>
            Forge New Tournament
        </h2>
        <div class="mt-3 flex gap-3 flex-wrap">
            <input type="text"
                   class="flex-1 min-w-[200px] rounded-xl border-2 border-fuchsia-400/30 bg-slate-950/80 px-4 py-3 text-slate-100 shadow-inner shadow-black/60 outline-none transition focus:border-fuchsia-400 focus:ring-4 focus:ring-fuchsia-500/30 placeholder:text-slate-500"
                   placeholder="Tournament name... (e.g. 'GOTY 2024 Showdown')"
                   @bind="_newTournamentName"
                   @onkeydown="HandleKeyDown" />
            <button class="group inline-flex items-center rounded-xl bg-gradient-to-r from-green-500 via-fuchsia-500 to-orange-500 bg-[length:300%_100%] px-6 py-3 text-sm font-black uppercase tracking-wide text-white shadow-mlg transition hover:-translate-y-1 hover:animate-sheen hover:scale-105 disabled:cursor-not-allowed disabled:opacity-60 disabled:hover:scale-100 disabled:hover:translate-y-0"
                    @onclick="CreateTournament"
                    disabled="@string.IsNullOrWhiteSpace(_newTournamentName)">
                <span class="mr-2 group-hover:animate-wiggle inline-block">⚔️</span>
                CREATE
            </button>
        </div>
        @if (!string.IsNullOrEmpty(_createMessage))
        {
            <p class="mt-3 text-sm font-bold text-green-200 animate-yeet">
                <span class="mr-1">🎉</span> @_createMessage
            </p>
        }
    </div>
</section>

<!-- Tournament list -->
<section class="mt-8 rounded-3xl border-2 border-green-400/20 bg-white/10 p-6 shadow-xl shadow-slate-950/50 backdrop-blur-xl md:p-8 animate-fade-in-up" style="animation-delay: 0.3s;">
    <div class="flex items-center gap-3">
        <h2 class="font-display text-2xl font-black text-white">📋 Your Tournaments</h2>
        <span class="text-xs font-black uppercase tracking-widest text-fuchsia-300/50 animate-pulse">SELECT YOUR ARENA</span>
    </div>

    @if (_tournaments.Count == 0)
    {
        <div class="mt-6 text-center py-8">
            <p class="text-5xl mb-3">🗿</p>
            <p class="text-slate-200 font-bold">No tournaments yet.</p>
            <p class="mt-1 text-sm text-slate-400">Create one above to get this party started, you absolute unit.</p>
        </div>
    }
    else
    {
        <div class="mt-5 grid gap-3">
            @foreach (var tournament in _tournaments)
            {
                var isActive = tournament.Id == _currentTournamentId;
                var gameCount = tournament.Games.Count;
                var duelCount = tournament.Duels.Count;
                var completedCount = tournament.Duels.Count(d => d.IsCompleted);

                <div class="@GetTournamentCardClass(isActive) group rounded-2xl border-2 p-5 backdrop-blur-lg transition hover:-translate-y-1 cursor-pointer"
                     @onclick="() => SelectTournament(tournament.Id)">
                    <div class="flex items-center justify-between flex-wrap gap-3">
                        <div>
                            <div class="flex items-center gap-2">
                                <h3 class="font-display text-xl font-black text-white">
                                    @if (isActive)
                                    {
                                        <span class="mr-1 animate-floaty inline-block">👑</span>
                                    }
                                    @tournament.Name
                                </h3>
                                @if (isActive)
                                {
                                    <span class="rounded-full bg-green-500/30 border border-green-400/50 px-2 py-0.5 text-[10px] font-black uppercase tracking-widest text-green-200 animate-pulse">ACTIVE</span>
                                }
                            </div>
                            <div class="mt-2 flex gap-3 text-xs font-bold text-slate-400">
                                <span>🎮 @gameCount game(s)</span>
                                <span>⚔️ @completedCount / @duelCount duels</span>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            @if (isActive)
                            {
                                <a href="/import" class="inline-flex items-center rounded-lg border border-orange-400/40 bg-orange-500/20 px-4 py-2 text-xs font-black uppercase tracking-wide text-orange-200 transition hover:bg-orange-500/30 hover:shadow-neon"
                                   @onclick:stopPropagation="true">
                                    <span class="mr-1">📥</span> Import
                                </a>
                                <a href="/vote" class="inline-flex items-center rounded-lg border border-fuchsia-400/40 bg-fuchsia-500/20 px-4 py-2 text-xs font-black uppercase tracking-wide text-fuchsia-200 transition hover:bg-fuchsia-500/30 hover:shadow-neon"
                                   @onclick:stopPropagation="true">
                                    <span class="mr-1">⚔️</span> Vote
                                </a>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded-lg border border-fuchsia-400/30 bg-fuchsia-500/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-fuchsia-300/70">
                                    Click to activate
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@code {
    private List<Tournament> _tournaments = new();
    private Guid? _currentTournamentId;
    private string _newTournamentName = string.Empty;
    private string _createMessage = string.Empty;

    protected override void OnInitialized()
    {
        LoadTournaments();
    }

    private void LoadTournaments()
    {
        _tournaments = GameService.GetTournaments();
        _currentTournamentId = GameService.GetCurrentTournament()?.Id;
    }

    private void CreateTournament()
    {
        if (string.IsNullOrWhiteSpace(_newTournamentName))
            return;

        var tournament = GameService.CreateTournament(_newTournamentName);
        _createMessage = $"Tournament \"{tournament.Name}\" has been forged! It's now the active arena. 🔥";
        _newTournamentName = string.Empty;
        LoadTournaments();
    }

    private void SelectTournament(Guid tournamentId)
    {
        GameService.SelectTournament(tournamentId);
        _createMessage = string.Empty;
        LoadTournaments();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            CreateTournament();
    }

    private static string GetTournamentCardClass(bool isActive) => isActive
        ? "border-green-400/50 bg-gradient-to-r from-green-500/20 via-fuchsia-500/10 to-orange-500/10 shadow-neon"
        : "border-fuchsia-400/20 bg-black/30 hover:border-fuchsia-400/50 hover:shadow-neon";
}
