@page "/Error"
@using System.Diagnostics

<PageTitle>💀 BRUH MOMENT 💀</PageTitle>

<section class="relative overflow-hidden rounded-3xl border-2 border-red-500/50 bg-red-950/30 p-8 shadow-2xl shadow-red-900/50 backdrop-blur-xl md:p-12 animate-fade-in-up">
    <div class="pointer-events-none absolute -right-10 -top-16 h-52 w-52 rounded-full bg-red-500/30 blur-3xl animate-pulse"></div>
    <div class="pointer-events-none absolute -left-16 bottom-0 h-48 w-48 rounded-full bg-orange-500/25 blur-3xl animate-pulse" style="animation-delay: 0.5s;"></div>

    <div class="text-center mb-6">
        <p class="text-7xl mb-4">🔥🐕🔥</p>
        <h1 class="font-display text-4xl font-black text-red-300 md:text-5xl">THIS IS FINE.</h1>
        <p class="mt-2 text-xl font-bold text-red-200/80">
            (narrator: it was, in fact, not fine)
        </p>
    </div>

    <div class="rounded-2xl border-2 border-red-500/30 bg-red-900/20 p-6 text-center">
        <h2 class="font-display text-2xl font-bold text-red-200 mb-2">💀 An error occurred while processing your request 💀</h2>
        <p class="text-sm text-red-300/70">
            Something went wrong. It's not you, it's us. Actually, it might be you. We don't know. We're just a website.
        </p>
    </div>

    @if (ShowRequestId)
    {
        <div class="mt-4 rounded-xl border border-red-500/20 bg-black/30 p-4">
            <p class="text-xs font-black uppercase tracking-widest text-red-300/50 mb-1">🔍 Request ID (for the nerds)</p>
            <code class="text-sm text-fuchsia-300 font-mono">@RequestId</code>
        </div>
    }

    <div class="mt-6 rounded-2xl border-2 border-dashed border-orange-500/30 bg-orange-900/10 p-5">
        <h3 class="font-display text-lg text-orange-200 mb-2">
            <span class="animate-wiggle inline-block mr-1">⚠️</span>
            Development Mode Stuff
        </h3>
        <p class="text-sm text-slate-300">
            Swapping to <strong class="text-orange-300">Development</strong> environment will show more detailed info about what went kaboom. 💥
        </p>
        <p class="mt-2 text-sm text-slate-300">
            <strong class="text-red-300">Don't enable Development in production.</strong>
            Unless you want to speedrun a security incident. Your call, chief. 🫡
        </p>
        <p class="mt-2 text-xs text-slate-500">
            Set <code class="text-fuchsia-400 bg-black/30 px-1 rounded">ASPNETCORE_ENVIRONMENT</code> to <code class="text-green-400 bg-black/30 px-1 rounded">Development</code> and restart the app.
            Or just stare at this page. We won't judge.
        </p>
    </div>

    <div class="mt-6 text-center">
        <a href="/" class="inline-flex items-center rounded-2xl bg-gradient-to-r from-fuchsia-500 via-green-500 to-orange-500 bg-[length:300%_100%] px-8 py-3 text-sm font-black uppercase tracking-wide text-white shadow-mlg transition hover:-translate-y-1 hover:animate-sheen">
            <span class="mr-2">🏠</span>
            Take Me Home (Country Roads)
        </a>
        <p class="mt-2 text-[10px] text-slate-500">🎵 To the place I belong 🎵</p>
    </div>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
