    private List<PendingMatchOption> GetPendingMatchOptions(Guid gameId)
    {
        var gameTitlesById = _games.ToDictionary(g => g.Id, g => g.Title);

        return GameService.GetPendingDuels()
            .Where(d => d.Game1Id == gameId || d.Game2Id == gameId)
            .Select(d =>
            {
                var opponentId = d.Game1Id == gameId ? d.Game2Id : d.Game1Id;
                gameTitlesById.TryGetValue(opponentId, out var opponentTitle);
                return new PendingMatchOption(d.Id, opponentId, opponentTitle ?? "Unknown title");
            })
            .OrderBy(x => x.OpponentTitle)
            .ToList();
    }

    private async Task PickPendingMatchWinner(PendingMatchOption pendingMatch, bool pickCurrentRowGame)
    {
        if (_pendingMatchesGameId is null)
            return;

        var winnerId = pickCurrentRowGame ? _pendingMatchesGameId.Value : pendingMatch.OpponentId;
        await RecordVote(pendingMatch.DuelId, winnerId, animateCurrentDuelButtons: false, isLeft: false);

        _pendingMatchOptions = GetPendingMatchOptions(_pendingMatchesGameId.Value);
        if (_pendingMatchOptions.Count == 0)
        {
            ClosePendingMatchesDialog();
        }
    }

    private void ClosePendingMatchesDialog()
    {
        _showPendingMatchesDialog = false;
        _pendingMatchesGameId = null;
        _pendingMatchesGameTitle = string.Empty;
        _pendingMatchOptions = [];
    }

    private static TitleDisplay GetTitleDisplay(string gameTitle)
    {
        if (string.IsNullOrWhiteSpace(gameTitle))
        {
            return new(gameTitle, null);
        }

        var trimmedTitle = gameTitle.Trim();
        if (!trimmedTitle.EndsWith(")", StringComparison.Ordinal))
        {
            return new(trimmedTitle, null);
        }

        var openingParenthesisIndex = trimmedTitle.LastIndexOf('(');
        if (openingParenthesisIndex <= 0 || openingParenthesisIndex >= trimmedTitle.Length - 1)
        {
            return new(trimmedTitle, null);
        }

        var title = trimmedTitle[..openingParenthesisIndex].TrimEnd();
        if (string.IsNullOrWhiteSpace(title))
        {
            return new(trimmedTitle, null);
        }

        var parenthesisContent = trimmedTitle[(openingParenthesisIndex + 1)..^1];
        if (string.IsNullOrWhiteSpace(parenthesisContent))
        {
            return new(title, null);
        }

        var subtitleParts = parenthesisContent
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Select(part => $"{title} {part}")
            .ToList();

        if (subtitleParts.Count == 0)
        {
            return new(title, null);
        }

        return new(title, string.Join(", ", subtitleParts));
    }

