    private static (string Icons, string Text) GetVibeDisplay(int rank)
    {
        var vibe = GetVibeCheck(rank);
        var parts = vibe.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0)
        {
            return (string.Empty, vibe);
        }

        var start = 0;
        while (start < parts.Length && IsVibeIconToken(parts[start]))
        {
            start++;
        }

        var end = parts.Length - 1;
        while (end >= start && IsVibeIconToken(parts[end]))
        {
            end--;
        }

        var leadingIcons = start > 0 ? string.Join(' ', parts[..start]) : string.Empty;
        var trailingIcons = end + 1 < parts.Length ? string.Join(' ', parts[(end + 1)..]) : string.Empty;
        var icons = string.IsNullOrWhiteSpace(leadingIcons)
            ? trailingIcons
            : string.IsNullOrWhiteSpace(trailingIcons)
                ? leadingIcons
                : $"{leadingIcons} {trailingIcons}";

        var text = start <= end ? string.Join(' ', parts[start..(end + 1)]) : vibe;
        return (icons, text);
    }

    private static bool IsVibeIconToken(string token)
    {
        foreach (var character in token)
        {
            if (char.IsLetterOrDigit(character))
            {
                return false;
            }
        }

        return token.Length > 0;
    }
