@page "/vote"
@rendermode InteractiveServer
@using BestestGame.Models
@using BestestGame.Services
@inject GameService GameService
@inject NavigationManager Navigation

<PageTitle>1v1 Me Bro | MLG Vote Arena 🎺</PageTitle>

@if (_currentTournament is null)
{
    <section class="relative overflow-hidden rounded-3xl border-2 border-amber-400/30 bg-white/10 p-6 shadow-2xl shadow-amber-900/40 backdrop-blur-xl md:p-8 animate-fade-in-up">
        <div class="mt-2 text-center py-8">
            <p class="text-5xl mb-3">🤔</p>
            <p class="text-slate-200 font-bold text-xl">No tournament selected, fam.</p>
            <p class="mt-2 text-sm text-slate-400">You need to create or select a tournament before you can vote.</p>
            <a href="/tournaments" class="mt-4 inline-flex items-center rounded-2xl bg-gradient-to-r from-fuchsia-500 via-green-500 to-orange-500 bg-[length:300%_100%] px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-mlg transition hover:-translate-y-1 hover:animate-sheen hover:scale-105">
                <span class="mr-2">🏟️</span> Go to Tournaments
            </a>
        </div>
    </section>
}
else
{
<section class="relative overflow-hidden rounded-3xl border-2 border-fuchsia-400/30 bg-white/10 p-6 shadow-2xl shadow-fuchsia-900/50 backdrop-blur-xl md:p-8 animate-fade-in-up">
    <div class="pointer-events-none absolute -top-12 right-6 h-48 w-48 rounded-full bg-fuchsia-400/30 blur-3xl animate-pulse"></div>
    <div class="pointer-events-none absolute -bottom-8 left-10 h-36 w-36 rounded-full bg-green-400/25 blur-3xl animate-pulse" style="animation-delay: 0.7s;"></div>

    <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-display text-3xl font-black text-white md:text-4xl">
            <span class="animate-skull inline-block">💀</span>
            VOTE ARENA
            <span class="animate-skull inline-block" style="animation-delay: 0.25s;">💀</span>
        </h1>
        <span class="rounded-full bg-red-500/30 border-2 border-red-400/50 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-red-200 animate-pulse">🔴 LIVE</span>
        <span class="rounded-full bg-fuchsia-500/30 border border-fuchsia-400/50 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-fuchsia-200">🏟️ @_currentTournament.Name</span>
    </div>
    <p class="text-xs text-fuchsia-300/60 font-bold mt-1">Final Destination • No Items • Fox Only • Best Game Wins</p>

    @if (_currentDuel == null)
    {
        <div class="mt-6 rounded-2xl border-2 border-green-400/50 bg-green-500/20 p-6 text-green-50 text-center">
            <p class="text-4xl mb-2">🏆</p>
            <p class="font-display text-2xl font-black">GG WP! ALL DUELS COMPLETE!</p>
            <p class="mt-2 text-sm text-green-200/80">The tournament is over. Check the standings below, you absolute legend. 💯</p>
            <p class="mt-2 text-xs text-green-300/50">*airhorn noises* 🎺🎺🎺</p>
        </div>
    }
    else
    {
        <p class="mt-3 text-slate-200">Choose your fighter. There can only be one. <span class="text-fuchsia-300">Choose wisely.</span> <span class="text-[10px] text-slate-400">(or don't, we're not the boss of you)</span></p>

        <div class="my-8 grid gap-4 md:grid-cols-[1fr_auto_1fr] md:items-center">
            <button class="@_leftButtonClass"
                    @onclick="() => CastVote(_game1!.Id, true)">
                <span class="absolute -top-4 -left-4 text-3xl animate-floaty">🔥</span>
                <span class="font-display">@_game1!.Title</span>
                <span class="absolute -bottom-3 -right-3 text-2xl opacity-0 group-hover:opacity-100 transition animate-wiggle">💪</span>
            </button>

            <div class="mx-auto flex flex-col items-center gap-2">
                <span class="inline-flex h-16 w-16 animate-floaty items-center justify-center rounded-full border-2 border-orange-400/50 bg-gradient-to-br from-orange-500/30 to-red-500/30 font-display text-2xl font-black text-orange-100 shadow-neon">
                    VS
                </span>
                <span class="text-[10px] font-black uppercase tracking-widest text-orange-300/50 animate-pulse">FIGHT!</span>
            </div>

            <button class="@_rightButtonClass"
                    @onclick="() => CastVote(_game2!.Id, false)">
                <span class="absolute -top-4 -right-4 text-3xl animate-floaty" style="animation-delay: 0.5s;">🔥</span>
                <span class="font-display">@_game2!.Title</span>
                <span class="absolute -bottom-3 -left-3 text-2xl opacity-0 group-hover:opacity-100 transition animate-wiggle">💪</span>
            </button>
        </div>

        <div class="flex justify-center my-2">
            <button class="rounded-2xl border-2 border-yellow-400/50 bg-gradient-to-r from-yellow-600/80 to-orange-600/80 px-6 py-3 text-sm font-black uppercase tracking-wider text-white shadow-lg transition-all duration-200 hover:-translate-y-1 hover:scale-105 hover:shadow-[0_0_40px_rgba(255,200,0,0.6)] active:scale-90 disabled:opacity-30 disabled:pointer-events-none"
                    disabled="@(!_canUndo)"
                    @onclick="UndoLastVote">
                <span class="mr-1">⏪</span> Woopsie
            </button>
        </div>

        <div class="flex flex-wrap items-center gap-4 text-sm">
            <div class="rounded-xl border border-fuchsia-500/30 bg-fuchsia-500/10 px-4 py-2">
                <span class="text-fuchsia-300/70 text-xs font-black uppercase tracking-widest">Remaining</span>
                <span class="ml-2 font-display text-lg font-black text-fuchsia-200">@_pendingCount</span>
            </div>
            <div class="rounded-xl border border-green-500/30 bg-green-500/10 px-4 py-2">
                <span class="text-green-300/70 text-xs font-black uppercase tracking-widest">Completed</span>
                <span class="ml-2 font-display text-lg font-black text-green-200">@_completedCount / @_totalCount</span>
            </div>
            <div class="rounded-xl border border-orange-500/30 bg-orange-500/10 px-4 py-2">
                <span class="text-orange-300/70 text-xs font-black uppercase tracking-widest">Hype Level</span>
                <span class="ml-2 font-display text-lg font-black text-orange-200 animate-rainbow">MAXIMUM</span>
            </div>
        </div>
    }
</section>

<!-- STANDINGS - The Hall of Dank -->
<section class="mt-8 rounded-3xl border-2 border-green-400/20 bg-white/10 p-6 shadow-xl shadow-slate-950/50 backdrop-blur-xl md:p-8 animate-fade-in-up" style="animation-delay: 0.3s;">
    <div class="flex items-center gap-3">
        <h2 class="font-display text-2xl font-black text-white">🏆 Hall of Dank™</h2>
        <span class="text-xs font-black uppercase tracking-widest text-yellow-300/50 animate-pulse">LEADERBOARD</span>
    </div>

    @if (_games.Count == 0)
    {
        <div class="mt-6 text-center py-8">
            <p class="text-5xl mb-3">🗿</p>
            <p class="text-slate-200 font-bold">No games imported yet.</p>
            <p class="mt-1 text-sm text-slate-400">Go to the <a href="/import" class="font-bold text-fuchsia-300 hover:text-fuchsia-200 transition">Yeet Games In</a> page to add games, you absolute walnut.</p>
        </div>
    }
    else
    {
        <div class="@_tableContainerClass" @key="_tableAnimKey">
            <table class="min-w-full divide-y divide-fuchsia-500/20 text-left">
                <thead class="bg-gradient-to-r from-fuchsia-900/60 via-green-900/40 to-orange-900/60 text-xs uppercase tracking-wider text-slate-100">
                    <tr>
                        <th class="px-4 py-3">🏅 Rank</th>
                        <th class="px-4 py-3">🎮 Title</th>
                        <th class="px-4 py-3">⭐ Points</th>
                        <th class="px-4 py-3">🎯 Matches</th>
                        <th class="px-4 py-3">📊 Vibe</th>
                        <th class="px-4 py-3">🔍 Losses</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-fuchsia-500/10 text-slate-100">
                    @{int rank = 1;}
                    @foreach (var game in _games)
                    {
                        var r = rank;
                        <tr class="@GetRowAnimClass(game, r)"
                            style="@GetRowAnimStyle(r)">
                            <td class="px-4 py-3 font-display text-lg font-black @GetRankColor(r)">
                                @GetRankDisplay(r)
                            </td>
                            <td class="px-4 py-3 font-bold text-lg">
                                @if (r == 1)
                                {
                                    <span class="rainbow-text">@game.Title</span>
                                }
                                else
                                {
                                    @game.Title
                                }
                            </td>
                            <td class="px-4 py-3 font-display font-black text-lg text-fuchsia-200">@game.Points</td>
                            <td class="px-4 py-3 font-display font-black text-lg text-green-200">@(_matchesPlayed.GetValueOrDefault(game.Id))</td>
                            <td class="px-4 py-3 text-sm">@GetVibeCheck(r)</td>
                            <td class="px-4 py-3 text-center">
                                @if (_gamesPickedOver.TryGetValue(game.Id, out var beaten) && beaten.Count > 0)
                                {
                                    <button class="rounded-xl border border-red-400/50 bg-red-500/20 px-3 py-1 text-xs font-bold text-red-200 transition hover:bg-red-500/40 hover:scale-105"
                                            @onclick="() => ShowBeatenBy(game.Title, beaten)">
                                        💀 @beaten.Count
                                    </button>
                                }
                                else
                                {
                                    <span class="text-xs text-green-300/60">✅ None</span>
                                }
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@if (_showBeatenByDialog)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm animate-fade-in-up" @onclick="CloseBeatenByDialog">
        <div class="relative mx-4 max-w-md w-full rounded-2xl border-2 border-red-400/30 bg-slate-900/95 p-6 shadow-2xl" @onclick:stopPropagation>
            <h3 class="font-display text-xl font-black text-red-200">
                💀 Games picked over <span class="text-fuchsia-300">@_beatenByGameTitle</span>
            </h3>
            <ul class="mt-4 max-h-64 space-y-2 overflow-y-auto pr-1">
                @foreach (var title in _beatenByList)
                {
                    <li class="rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-2 text-sm font-bold text-red-100">
                        🎮 @title
                    </li>
                }
            </ul>
            <button class="mt-5 w-full rounded-xl border-2 border-slate-500/40 bg-slate-700/60 px-4 py-2 text-sm font-black uppercase tracking-wider text-slate-200 transition hover:bg-slate-600/60"
                    @onclick="CloseBeatenByDialog">
                Close
            </button>
        </div>
    </div>
}
}

@code {
    private Tournament? _currentTournament;
    private Duel? _currentDuel;
    private Game? _game1;
    private Game? _game2;
    private List<Game> _games = new();
    private Dictionary<Guid, int> _matchesPlayed = new();
    private Dictionary<Guid, List<string>> _gamesPickedOver = new();
    private bool _showBeatenByDialog;
    private string _beatenByGameTitle = string.Empty;
    private List<string> _beatenByList = [];
    private int _pendingCount;
    private int _completedCount;
    private int _totalCount;
    private bool _justVoted;
    private bool _lastVoteLeft;
    private Guid _lastWinnerId;
    private int _tableAnimKey;
    private Guid? _lastCompletedDuelId;
    private bool _canUndo;

    protected override void OnInitialized()
    {
        _currentTournament = GameService.GetCurrentTournament();
        if (_currentTournament is not null)
            LoadNextDuel();
    }

    private void LoadNextDuel()
    {
        (_currentDuel, _game1, _game2) = GameService.GetRandomPendingDuel();
        _games = GameService.GetGames();
        _matchesPlayed = GameService.GetMatchesPlayedPerGame();
        _gamesPickedOver = GameService.GetGamesPickedOver();
        _totalCount = GameService.TotalDuels();
        _completedCount = GameService.CompletedDuels();
        _pendingCount = _totalCount - _completedCount;
    }

    private async Task CastVote(Guid winnerId, bool isLeft)
    {
        if (_currentDuel == null) return;

        _lastVoteLeft = isLeft;
        _lastWinnerId = winnerId;
        _justVoted = true;
        _tableAnimKey++;

        _lastCompletedDuelId = _currentDuel.Id;
        _canUndo = true;

        GameService.RecordWinner(_currentDuel.Id, winnerId);
        LoadNextDuel();

        // Let the animations play before clearing state
        await Task.Delay(600);
        _justVoted = false;
    }

    private void UndoLastVote()
    {
        if (!_canUndo || _lastCompletedDuelId is null)
            return;

        var duelId = _lastCompletedDuelId.Value;
        _canUndo = false;
        _lastCompletedDuelId = null;

        GameService.UndoMatch(duelId);

        // Reload the exact duel that was undone instead of a random one
        (_currentDuel, _game1, _game2) = GameService.GetDuel(duelId);
        _games = GameService.GetGames();
        _matchesPlayed = GameService.GetMatchesPlayedPerGame();
        _gamesPickedOver = GameService.GetGamesPickedOver();
        _totalCount = GameService.TotalDuels();
        _completedCount = GameService.CompletedDuels();
        _pendingCount = _totalCount - _completedCount;
        _tableAnimKey++;
    }

    private string GetButtonClass(string side)
    {
        if (!_justVoted) return "";
        var isWinner = (side == "left" && _lastVoteLeft) || (side == "right" && !_lastVoteLeft);
        return isWinner ? "animate-juice-pop" : "";
    }

    private const string LeftButtonBase = "group relative rounded-3xl border-2 border-fuchsia-400/50 bg-gradient-to-br from-fuchsia-600 via-purple-600 to-fuchsia-800 bg-[length:200%_100%] px-10 py-10 text-3xl md:text-4xl font-black text-white shadow-mlg transition-all duration-200 hover:-translate-y-2 hover:animate-sheen hover:scale-105 hover:shadow-[0_0_60px_rgba(255,0,255,1)] active:scale-90 active:brightness-125";
    private const string RightButtonBase = "group relative rounded-3xl border-2 border-green-400/50 bg-gradient-to-br from-green-600 via-emerald-600 to-green-800 bg-[length:200%_100%] px-10 py-10 text-3xl md:text-4xl font-black text-white shadow-mlg transition-all duration-200 hover:-translate-y-2 hover:animate-sheen hover:scale-105 hover:shadow-[0_0_60px_rgba(0,255,0,1)] active:scale-90 active:brightness-125";

    private string _leftButtonClass => $"{GetButtonClass("left")} {LeftButtonBase}";
    private string _rightButtonClass => $"{GetButtonClass("right")} {RightButtonBase}";

    private string _tableContainerClass => $"mt-5 overflow-hidden rounded-2xl border-2 border-fuchsia-400/20 {(_justVoted ? "animate-table-slam" : "")}";

    private string GetRowAnimClass(Game game, int rank) =>
        $"{GetRowClass(rank)} {(_justVoted ? "animate-row-cascade" : "")} transition hover:bg-fuchsia-500/15 hover:shadow-neon {(game.Id == _lastWinnerId ? "animate-victory-burst" : "")}";

    private string GetRowAnimStyle(int rank) =>
        _justVoted ? $"animation-delay: {(rank - 1) * 50}ms" : "";

    private static string GetRankDisplay(int rank) => rank switch
    {
        1 => "👑 #1",
        2 => "🥈 #2",
        3 => "🥉 #3",
        _ => $"#{rank}"
    };

    private static string GetRankColor(int rank) => rank switch
    {
        1 => "text-yellow-300",
        2 => "text-slate-300",
        3 => "text-orange-400",
        _ => "text-fuchsia-300/70"
    };

    private static string GetRowClass(int rank) => rank switch
    {
        1 => "bg-yellow-500/10 border-l-4 border-l-yellow-400",
        2 => "bg-slate-400/5 border-l-4 border-l-slate-400",
        3 => "bg-orange-500/5 border-l-4 border-l-orange-500",
        _ => "bg-black/20"
    };

    private void ShowBeatenBy(string gameTitle, List<string> beatenBy)
    {
        _beatenByGameTitle = gameTitle;
        _beatenByList = beatenBy;
        _showBeatenByDialog = true;
    }

    private void CloseBeatenByDialog()
    {
        _showBeatenByDialog = false;
    }

    private static string GetVibeCheck(int rank) => rank switch
    {
        1 => "🔥 GOAT 🐐",
        2 => "💪 Sigma grindset",
        3 => "✨ Based",
        4 => "👍 Bussin",
        5 => "🙂 Mid but valid",
        _ => "🗿 Exists"
    };
}
