@page "/import"
@rendermode InteractiveServer
@using BestestGame.Services
@inject GameService GameService

<PageTitle>Import</PageTitle>

<section class="relative overflow-hidden rounded-3xl border border-white/20 bg-white/10 p-6 shadow-2xl shadow-cyan-900/50 backdrop-blur-xl md:p-8">
    <div class="pointer-events-none absolute -left-12 top-16 h-36 w-36 rounded-full bg-fuchsia-500/25 blur-3xl"></div>
    <h1 class="font-display text-3xl font-black text-white md:text-4xl">📥 Import Vault</h1>

    <p class="mt-3 text-slate-100/90">Enter one game title per line. Hit <strong>Import</strong> and all missing duels will be generated automatically.</p>

    <div class="mt-6">
        <label for="gameTitles" class="mb-2 block text-sm font-black uppercase tracking-[0.18em] text-cyan-100">Game Titles</label>
        <textarea id="gameTitles"
                  class="min-h-64 w-full rounded-2xl border border-cyan-300/35 bg-slate-950/80 p-4 text-slate-100 shadow-inner shadow-black/60 outline-none transition focus:border-fuchsia-400 focus:ring-4 focus:ring-fuchsia-500/30"
                  placeholder="Enter one game title per line..."
                  @bind="_inputText"></textarea>
    </div>

    <button class="mt-6 inline-flex items-center rounded-2xl border border-white/25 bg-gradient-to-r from-fuchsia-500 via-violet-500 to-cyan-500 bg-[length:200%_100%] px-6 py-3 text-sm font-black uppercase tracking-wide text-white shadow-neon transition hover:-translate-y-1 hover:animate-sheen disabled:cursor-not-allowed disabled:opacity-60"
            @onclick="ImportGames" disabled="@_isImporting">
        @if (_isImporting)
        {
            <span class="mr-2 inline-block h-4 w-4 animate-spin rounded-full border-2 border-white/30 border-t-white"></span>
            <span>Importing...</span>
        }
        else
        {
            <span>Import</span>
        }
    </button>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="@GetAlertClasses() mt-5 rounded-2xl border px-4 py-3 text-sm font-bold">@_message</div>
    }
</section>

@code {
    private string _inputText = string.Empty;
    private string _message = string.Empty;
    private string _alertClass = "alert-success";
    private bool _isImporting = false;

    private void ImportGames()
    {
        var titles = _inputText
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .ToList();

        if (titles.Count == 0)
        {
            _alertClass = "alert-warning";
            _message = "Please enter at least one game title.";
            return;
        }

        _isImporting = true;
        GameService.ImportGames(titles);
        _isImporting = false;

        _alertClass = "alert-success";
        _message = $"Successfully imported {titles.Count} game title(s). Head to the Vote page to start voting!";
        _inputText = string.Empty;
    }

    private string GetAlertClasses() => _alertClass == "alert-warning"
        ? "border-amber-300/45 bg-amber-400/25 text-amber-50"
        : "border-emerald-300/45 bg-emerald-400/25 text-emerald-50";
}
