@page "/"

<PageTitle>Home | such game, very wow 🐕</PageTitle>

<!-- HERO SECTION - Maximum Meme Energy -->
<section class="relative overflow-hidden rounded-3xl border-2 border-fuchsia-400/30 bg-white/10 p-8 shadow-2xl shadow-fuchsia-900/50 backdrop-blur-xl md:p-12 animate-fade-in-up">
    <div class="pointer-events-none absolute -right-10 -top-16 h-52 w-52 rounded-full bg-green-400/25 blur-2xl animate-pulse"></div>
    <div class="pointer-events-none absolute -left-16 bottom-0 h-48 w-48 rounded-full bg-fuchsia-400/25 blur-2xl animate-pulse" style="animation-delay: 0.7s;"></div>
    <div class="pointer-events-none absolute right-1/4 top-1/3 h-32 w-32 rounded-full bg-orange-400/20 blur-2xl animate-pulse" style="animation-delay: 1.2s;"></div>

    <div class="flex items-center gap-2 mb-4">
        <p class="inline-flex rounded-full border-2 border-fuchsia-400/50 bg-gradient-to-r from-fuchsia-500/30 to-green-500/30 px-4 py-1 text-xs font-black uppercase tracking-[0.2em] text-fuchsia-100 shadow-neon">
            <span class="mr-1 animate-skull">💀</span> Bestest Tournament Arena <span class="ml-1 animate-skull" style="animation-delay: 0.25s;">💀</span>
        </p>
        <span class="rounded-full bg-green-500/30 border border-green-400/50 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-green-200 animate-pulse">LEGENDARY</span>
    </div>

    <h1 class="font-display text-4xl font-black tracking-tight text-white md:text-6xl leading-tight">
        Make your game list
        <span class="rainbow-text block md:inline"> absolutely legendary</span>
    </h1>

    <p class="mt-4 text-2xl font-bold animate-wiggle inline-block">
        🐕 wow 🐕 such ranking 🐕 very tournament 🐕
    </p>

    <p class="mt-3 max-w-2xl text-lg text-slate-100/90">
        Import your titles, throw them into <span class="font-black text-fuchsia-300">DRAMATIC 1v1 duels</span>,
        and forge a ranking board worthy of <span class="font-black text-green-300">the dankest champions</span>.
        No cap, this thing goes harder than a 360 no-scope at 3am. Fr fr. 💯
    </p>

    <!-- action buttons -->
    <div class="mt-8 flex flex-wrap gap-4">
        <a href="/vote" class="group inline-flex items-center rounded-2xl bg-gradient-to-r from-fuchsia-500 via-green-500 to-orange-500 bg-[length:300%_100%] px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-mlg transition hover:-translate-y-1 hover:animate-sheen hover:scale-105">
            <span class="mr-2 group-hover:animate-wiggle">⚔️</span>
            Start Voting
            <span class="ml-2 group-hover:animate-skull">⚡</span>
        </a>
        <a href="/import" class="group inline-flex items-center rounded-2xl border-2 border-fuchsia-300/40 bg-fuchsia-400/20 px-7 py-4 text-sm font-extrabold uppercase tracking-wide text-fuchsia-50 transition hover:-translate-y-1 hover:bg-fuchsia-300/30 hover:shadow-neon">
            <span class="mr-2 group-hover:animate-wiggle">📥</span>
            Yeet Games In
        </a>
    </div>

    <!-- How it works - meme edition -->
    <div class="mt-10 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border-2 border-fuchsia-400/25 bg-black/30 p-5 backdrop-blur-lg transition hover:-translate-y-1 hover:border-fuchsia-400/50 hover:shadow-neon">
            <div class="flex items-center gap-2">
                <p class="text-xs font-black uppercase tracking-widest text-fuchsia-200">Step 1</p>
                <span class="text-lg animate-floaty">📋</span>
            </div>
            <p class="mt-2 font-display text-lg font-bold text-white">Yeet your list</p>
            <p class="mt-1 text-sm text-slate-200">Drop in all game titles. The more the merrier. Go touch some grass after. Or don't. We're not your mom.</p>
        </div>
        <div class="rounded-2xl border-2 border-green-400/25 bg-black/30 p-5 backdrop-blur-lg transition hover:-translate-y-1 hover:border-green-400/50 hover:shadow-neon">
            <div class="flex items-center gap-2">
                <p class="text-xs font-black uppercase tracking-widest text-green-200">Step 2</p>
                <span class="text-lg animate-floaty" style="animation-delay: 0.3s;">⚔️</span>
            </div>
            <p class="mt-2 font-display text-lg font-bold text-white">1v1 them bro</p>
            <p class="mt-1 text-sm text-slate-200">Choose winners in EPIC 1v1 matchups. Final Destination. No items. Fox only. You know the drill.</p>
        </div>
        <div class="rounded-2xl border-2 border-orange-400/25 bg-black/30 p-5 backdrop-blur-lg transition hover:-translate-y-1 hover:border-orange-400/50 hover:shadow-neon">
            <div class="flex items-center gap-2">
                <p class="text-xs font-black uppercase tracking-widest text-orange-200">Step 3</p>
                <span class="text-lg animate-floaty" style="animation-delay: 0.6s;">👑</span>
            </div>
            <p class="mt-2 font-display text-lg font-bold text-white">Crown the GOAT</p>
            <p class="mt-1 text-sm text-slate-200">Watch the leaderboard settle. The cream rises to the top. And by cream we mean the bestest game. 🐐</p>
        </div>
    </div>
</section>

